{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snipcast",
  "version": "0.32.0",
  "identifier": "com.snipcast.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Snipcast",
        "width": 728,
        "height": 400,
        "minWidth": 624,
        "minHeight": 320,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "backgroundColor": "#1b1b1f",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "focus": true
      },
      {
        "label": "settings",
        "url": "index.html?snipcast=settings",
        "title": "Настройки — Snipcast",
        "width": 880,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "backgroundColor": "#1b1b1f",
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Text templates from the tray",
    "longDescription": "Snipcast — palette of text templates (macOS & Windows)."
  }
}
